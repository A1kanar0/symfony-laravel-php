{
	"info": {
		"name": "Symfony - Album API (CRUD)",
		"description": "Колекція запитів для тестування CRUD операцій сутності Album, реалізованих на фреймворку Symfony. Порт змінено на 8001 для паралельного тестування.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "1. Отримати список альбомів",
			"request": {
				"method": "GET",
				"header": [
					{
						"key": "Accept",
						"value": "application/json"
					}
				],
				"url": {
					"raw": "{{baseUrl}}/albums",
					"host": [
						"{{baseUrl}}"
					],
					"path": [
						"albums"
					]
				},
				"description": "Повертає масив усіх збережених альбомів із контролера Symfony."
			},
			"response": []
		},
		{
			"name": "2. Створити новий альбом",
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"title\": \"Hotel California\",\n    \"artist\": \"Eagles\",\n    \"year\": 1976\n}"
				},
				"url": {
					"raw": "{{baseUrl}}/albums",
					"host": [
						"{{baseUrl}}"
					],
					"path": [
						"albums"
					]
				},
				"description": "Створює запис альбому в пам'яті Symfony-контролера."
			},
			"response": []
		},
		{
			"name": "3. Отримати альбом за ID",
			"request": {
				"method": "GET",
				"header": [
					{
						"key": "Accept",
						"value": "application/json"
					}
				],
				"url": {
					"raw": "{{baseUrl}}/albums/2",
					"host": [
						"{{baseUrl}}"
					],
					"path": [
						"albums",
						"2"
					]
				},
				"description": "Отримання одного альбому (з ID = 2)."
			},
			"response": []
		},
		{
			"name": "4. Оновити альбом",
			"request": {
				"method": "PATCH",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"title\": \"Hotel California (Remastered)\"\n}"
				},
				"url": {
					"raw": "{{baseUrl}}/albums/2",
					"host": [
						"{{baseUrl}}"
					],
					"path": [
						"albums",
						"2"
					]
				},
				"description": "Часткове оновлення (PATCH) альбому за його ідентифікатором."
			},
			"response": []
		},
		{
			"name": "5. Видалити альбом",
			"request": {
				"method": "DELETE",
				"header": [],
				"url": {
					"raw": "{{baseUrl}}/albums/2",
					"host": [
						"{{baseUrl}}"
					],
					"path": [
						"albums",
						"2"
					]
				},
				"description": "Видалення альбому."
			},
			"response": []
		}
	],
	"variable": [
		{
			"key": "baseUrl",
			"value": "http://127.0.0.1:8001/api",
			"type": "string"
		}
	]
}